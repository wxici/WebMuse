<Window x:Class="WebRebuildRecorder.App.Views.DetachedPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="WebView2 独立预览"
        Width="1440"
        Height="900"
        MinWidth="390"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F4F5F7">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   LastChildFill="True"
                   Margin="0,0,0,8">
            <TextBlock Text="独立 WebView2 预览"
                       FontSize="18"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       DockPanel.Dock="Left" />
            <TextBlock x:Name="ViewportStatusText"
                       Text="尺寸：--"
                       Foreground="#57606A"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Right"
                       DockPanel.Dock="Right" />
        </DockPanel>

        <Grid Grid.Row="1"
              Margin="0,0,0,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBox Grid.Row="0"
                     x:Name="AddressBox"
                     MinWidth="260"
                     VerticalContentAlignment="Center"
                     Padding="8,5"
                     Margin="0,0,0,8" />

            <WrapPanel Grid.Row="1">
                <Button Content="打开"
                        Click="NavigateButton_Click"
                        Padding="12,6"
                        Margin="0,0,8,8" />
                <Button Content="刷新"
                        Click="RefreshButton_Click"
                        Padding="12,6"
                        Margin="0,0,8,8" />
                <Button Content="外部浏览器"
                        Click="OpenExternalButton_Click"
                        Padding="12,6"
                        Margin="0,0,8,8" />
            </WrapPanel>

            <WrapPanel Grid.Row="2">
                <Button Content="1366 × 768"
                        Click="Desktop1366Button_Click"
                        Padding="10,5"
                        Margin="0,0,8,8" />
                <Button Content="1440 × 900"
                        Click="Desktop1440Button_Click"
                        Padding="10,5"
                        Margin="0,0,8,8" />
                <Button Content="1920 × 1080"
                        Click="Desktop1920Button_Click"
                        Padding="10,5"
                        Margin="0,0,8,8" />
                <Button Content="1024 × 768"
                        Click="Tablet1024Button_Click"
                        Padding="10,5"
                        Margin="0,0,8,8" />
                <Button Content="390 × 844"
                        Click="Phone390Button_Click"
                        Padding="10,5"
                        Margin="0,0,8,8" />
            </WrapPanel>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="#D0D7DE"
                BorderThickness="1"
                Background="White"
                CornerRadius="4">
            <wv2:WebView2 x:Name="DetachedPreviewWebView" />
        </Border>

        <TextBlock Grid.Row="3"
                   x:Name="StatusText"
                   Text="独立预览窗口：尚未加载页面。"
                   Foreground="#57606A"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap" />
    </Grid>
</Window>
