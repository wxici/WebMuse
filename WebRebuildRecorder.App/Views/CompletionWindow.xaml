<Window x:Class="WebRebuildRecorder.App.Views.CompletionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务已完成"
        Width="720"
        Height="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Topmost="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="任务已完成"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12" />

        <TextBox Grid.Row="1"
                 x:Name="DetailsBox"
                 IsReadOnly="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 Padding="10" />

        <WrapPanel Grid.Row="2"
                   HorizontalAlignment="Right"
                   Margin="0,12,0,0">
            <Button Content="打开 ChatGPT"
                    Click="OpenChatGptButton_Click"
                    Padding="12,6"
                    Margin="0,0,8,8" />
            <Button Content="复制提示词"
                    Click="CopyPromptButton_Click"
                    Padding="12,6"
                    Margin="0,0,8,8" />
            <Button Content="复制 ZIP 路径"
                    Click="CopyZipPathButton_Click"
                    Padding="12,6"
                    Margin="0,0,8,8" />
            <Button Content="打开上传包目录"
                    Click="OpenPackageButton_Click"
                    Padding="12,6"
                    Margin="0,0,8,8" />
            <Button Content="打开项目目录"
                    Click="OpenProjectButton_Click"
                    Padding="12,6"
                    Margin="0,0,8,8" />
            <Button Content="关闭"
                    Click="CloseButton_Click"
                    Padding="12,6"
                    Margin="0,0,0,8" />
        </WrapPanel>

        <TextBlock Grid.Row="3"
                   x:Name="StatusText"
                   Foreground="#57606A"
                   Text="该面板为非模态窗口，主窗口和悬浮工具条仍可操作。" />
    </Grid>
</Window>
