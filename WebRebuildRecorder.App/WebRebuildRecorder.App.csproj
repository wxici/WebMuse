<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
  </PropertyGroup>

  <ItemGroup>
    <None Include="Templates\observation-template.md" CopyToOutputDirectory="PreserveNewest" />
    <None Include="ConfigDefaults\*.json" CopyToOutputDirectory="PreserveNewest" />
    <None Include="Tools\ffmpeg\ffmpeg.exe" CopyToOutputDirectory="PreserveNewest" Condition="Exists('Tools\ffmpeg\ffmpeg.exe')" />
    <None Include="Tools\ffmpeg\ffprobe.exe" CopyToOutputDirectory="PreserveNewest" Condition="Exists('Tools\ffmpeg\ffprobe.exe')" />
  </ItemGroup>

</Project>
